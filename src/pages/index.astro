---
import BaseLayout from '../layouts/BaseLayout.astro'
import CheckIcon from '../components/icons/CheckIcon.astro'
import LocationIcon from '../components/icons/LocationIcon.astro'
import WhatsappIcon from '../components/icons/WhatsappIcon.astro'
import { Image } from 'astro:assets'
import bannerImage from '../assets/images/banner.jpg'
---

<BaseLayout
	title='Electroplating Services in Nashik, India — Copper, Nickel, Zinc & Tin Plating'
	description='Platinex Industries offers precision copper, nickel, zinc, and tin electroplating services in Nashik MIDC for electrical, switchgear, automobile, and electronics industries. Fast 1-day turnaround with strict QA.'
>
	<div class='mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8'>
		<section class='grid gap-12 md:gap-20'>
			<!-- Hero -->
			<div
				class='relative rounded-2xl md:rounded-3xl overflow-hidden ring-1 ring-stone-200/70 dark:ring-white/10 min-h-[400px] md:min-h-[560px] flex flex-col justify-center'
			>
				<Image
					src={bannerImage}
					alt='Electroplating production facility at Platinex Industries, Nashik MIDC — copper, nickel, zinc and tin plating lines'
					class='absolute inset-0 w-full h-full object-cover opacity-30 md:opacity-25'
					widths={[400, 800, 1200]}
					sizes='(max-width: 600px) 400px, (max-width: 1200px) 800px, 1200px'
					loading='eager'
					fetchpriority='high'
					quality={60}
				/>
				<div class='absolute inset-0 bg-gradient-to-t from-stone-900/15 to-transparent'></div>
				<div class='relative z-10 px-5 py-10 md:px-12 md:py-20'>
					<h1 class='text-3xl sm:text-4xl md:text-6xl font-extrabold leading-tight tracking-tight'>
						<span class='accent-underline'>Precision Electroplating Services</span> in Nashik, India
						— Copper, Nickel, Zinc &amp; Tin Plating
					</h1>
					<p class='mt-4 md:mt-5 text-lg md:text-xl text-stone-700 dark:text-stone-300 max-w-3xl'>
						Nashik's trusted electroplating partner — high‑quality copper, nickel, zinc &amp; tin
						plating with strict QA, 1-day turnaround, and 24×7 operations for electrical, switchgear
						&amp; automobile industries.
					</p>
					<div class='mt-6 md:mt-7 flex flex-wrap gap-3'>
						<a href='/blog' class='px-5 py-3 rounded-md bg-accent text-white font-semibold'
							>Visit Blog</a
						>
						<a
							href='#services'
							class='px-5 py-3 rounded-md border border-stone-300 dark:border-stone-700 font-semibold hover:border-accent hover:text-accent transition-colors'
							>Our Services</a
						>
					</div>
				</div>
			</div>

			<!-- Services -->
			<section id='services' class='grid gap-8'>
				<h2 class='text-2xl md:text-3xl font-bold tracking-tight'>Our Plating Services</h2>
				<div class='grid gap-6 md:gap-8 md:grid-cols-2 xl:grid-cols-4'>
					<!-- Card template: neutral surface with subtle border and accent top border -->
					<a
						href='/services/copper-plating'
						class='group rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 hover:border-accent transition-all duration-300'
					>
						<div class='h-1 w-10 bg-accent rounded-full'></div>
						<h3
							class='mt-4 text-lg font-semibold tracking-tight group-hover:text-accent transition-colors'
						>
							Copper Plating
						</h3>
						<p class='mt-2 text-sm leading-relaxed text-stone-600 dark:text-stone-400'>
							Highly conductive and smooth; used as base layer or functional coat.
						</p>
						<ul class='mt-4 space-y-2 text-sm'>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Purpose:</strong> Electrical conductivity, corrosion masking</span
								>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span><strong>Specs:</strong> 3 – 30 µm • Barrel Process</span>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Use:</strong> Electrical components, bus bars, grounding parts</span
								>
							</li>
						</ul>
					</a>

					<a
						href='/services/nickel-plating'
						class='group rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 hover:border-accent transition-all duration-300'
					>
						<div class='h-1 w-10 bg-accent rounded-full'></div>
						<h3
							class='mt-4 text-lg font-semibold tracking-tight group-hover:text-accent transition-colors'
						>
							Nickel Plating
						</h3>
						<p class='mt-2 text-sm leading-relaxed text-stone-600 dark:text-stone-400'>
							Hard, corrosion‑resistant, and arc‑resistant surface.
						</p>
						<ul class='mt-4 space-y-2 text-sm'>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span><strong>Purpose:</strong> Arc resistance, decorative finish</span
								>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Specs:</strong> 2 – 25 µm • Bright/Dull • Electrolytic</span
								>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span><strong>Use:</strong> Fasteners, shafts, valves, connectors</span
								>
							</li>
						</ul>
					</a>

					<a
						href='/services/zinc-plating'
						class='group rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 hover:border-accent transition-all duration-300'
					>
						<div class='h-1 w-10 bg-accent rounded-full'></div>
						<h3
							class='mt-4 text-lg font-semibold tracking-tight group-hover:text-accent transition-colors'
						>
							Zinc Plating
						</h3>
						<p class='mt-2 text-sm leading-relaxed text-stone-600 dark:text-stone-400'>
							Cost‑effective sacrificial rust protection for ferrous parts.
						</p>
						<ul class='mt-4 space-y-2 text-sm'>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Purpose:</strong> Rust protection, sacrificial coating</span
								>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Specs:</strong> 2 – 12 µm • Tri. Blue/Yellow/Green • Black Passivation</span
								>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Use:</strong> Hardware, fasteners, automotive components</span
								>
							</li>
						</ul>
					</a>

					<a
						href='/services/tin-plating'
						class='group rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-6 hover:border-accent transition-all duration-300'
					>
						<div class='h-1 w-10 bg-accent rounded-full'></div>
						<h3
							class='mt-4 text-lg font-semibold tracking-tight group-hover:text-accent transition-colors'
						>
							Tin Plating
						</h3>
						<p class='mt-2 text-sm leading-relaxed text-stone-600 dark:text-stone-400'>
							Soft, highly solderable coating with excellent corrosion resistance.
						</p>
						<ul class='mt-4 space-y-2 text-sm'>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Purpose:</strong> Solderability, corrosion resistance</span
								>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span><strong>Specs:</strong> 2 – 10 µm • Bright/Matte</span>
							</li>
							<li class='flex items-start gap-2'>
								<CheckIcon /><span
									><strong>Use:</strong> Switchgear, terminals, electrical contacts</span
								>
							</li>
						</ul>
					</a>
				</div>
				<div class='mt-8 text-center'>
					<a
						href='/services'
						class='inline-flex items-center gap-2 text-accent font-semibold hover:underline'
					>
						View All Services
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='h-4 w-4'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
						>
							<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5l7 7-7 7'
							></path>
						</svg>
					</a>
				</div>
			</section>

			<!-- Plating Services Image Gallery -->
			<section class='grid gap-8'>
				<h2 class='text-2xl md:text-3xl font-bold tracking-tight'>Our Plating Work Gallery</h2>
				<div class='grid gap-6 md:grid-cols-2 lg:grid-cols-4'>
					<div
						class='group relative overflow-hidden rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5'
					>
						<div
							class='aspect-square bg-gradient-to-br from-amber-100 to-amber-200 dark:from-amber-900/20 dark:to-amber-800/20 flex items-center justify-center'
						>
							<div class='text-center p-4'>
								<div
									class='w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-3'
								>
									<span class='text-2xl font-bold text-accent'>Cu</span>
								</div>
								<h3 class='font-semibold text-lg text-stone-900 dark:text-white'>Copper Plating</h3>
								<p class='text-sm text-stone-600 dark:text-stone-400 mt-1'>
									Electrical conductivity & corrosion resistance
								</p>
							</div>
						</div>
						<div
							class='absolute inset-0 bg-accent/0 group-hover:bg-accent/5 transition-colors duration-300'
						>
						</div>
					</div>

					<div
						class='group relative overflow-hidden rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5'
					>
						<div
							class='aspect-square bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-900/20 dark:to-slate-800/20 flex items-center justify-center'
						>
							<div class='text-center p-4'>
								<div
									class='w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-3'
								>
									<span class='text-2xl font-bold text-accent'>Ni</span>
								</div>
								<h3 class='font-semibold text-lg text-stone-900 dark:text-white'>Nickel Plating</h3>
								<p class='text-sm text-stone-600 dark:text-stone-400 mt-1'>
									Hard surface & arc resistance
								</p>
							</div>
						</div>
						<div
							class='absolute inset-0 bg-accent/0 group-hover:bg-accent/5 transition-colors duration-300'
						>
						</div>
					</div>

					<div
						class='group relative overflow-hidden rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5'
					>
						<div
							class='aspect-square bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900/20 dark:to-blue-800/20 flex items-center justify-center'
						>
							<div class='text-center p-4'>
								<div
									class='w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-3'
								>
									<span class='text-2xl font-bold text-accent'>Zn</span>
								</div>
								<h3 class='font-semibold text-lg text-stone-900 dark:text-white'>Zinc Plating</h3>
								<p class='text-sm text-stone-600 dark:text-stone-400 mt-1'>
									Rust protection & sacrificial coating
								</p>
							</div>
						</div>
						<div
							class='absolute inset-0 bg-accent/0 group-hover:bg-accent/5 transition-colors duration-300'
						>
						</div>
					</div>

					<div
						class='group relative overflow-hidden rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5'
					>
						<div
							class='aspect-square bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-900/20 dark:to-gray-800/20 flex items-center justify-center'
						>
							<div class='text-center p-4'>
								<div
									class='w-16 h-16 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-3'
								>
									<span class='text-2xl font-bold text-accent'>Sn</span>
								</div>
								<h3 class='font-semibold text-lg text-stone-900 dark:text-white'>Tin Plating</h3>
								<p class='text-sm text-stone-600 dark:text-stone-400 mt-1'>
									Solderability & corrosion resistance
								</p>
							</div>
						</div>
						<div
							class='absolute inset-0 bg-accent/0 group-hover:bg-accent/5 transition-colors duration-300'
						>
						</div>
					</div>
				</div>
			</section>

			<section class='grid gap-8'>
				<h2 class='text-2xl md:text-3xl font-bold tracking-tight'>Plating Thickness Range</h2>
				<div class='grid gap-4 md:grid-cols-2 xl:grid-cols-4 text-center md:text-left'>
					<div
						class='rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-6'
					>
						<h3 class='mt-2 text-lg font-semibold tracking-tight'>Copper</h3>
						<p class='text-3xl font-bold mt-1 text-accent'>
							2 – 30 <span class='text-base'>µm</span>
						</p>
					</div>
					<div
						class='rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6'
					>
						<h3 class='mt-2 text-lg font-semibold tracking-tight'>Nickel</h3>
						<p class='text-3xl font-bold mt-1 text-accent'>
							2 – 25 <span class='text-base'>µm</span>
						</p>
					</div>
					<div
						class='rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6'
					>
						<h3 class='mt-2 text-lg font-semibold tracking-tight'>Zinc</h3>
						<p class='text-3xl font-bold mt-1 text-accent'>
							2 – 12 <span class='text-base'>µm</span>
						</p>
					</div>
					<div
						class='rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-6'
					>
						<h3 class='mt-2 text-lg font-semibold tracking-tight'>Tin</h3>
						<p class='text-3xl font-bold mt-1 text-accent'>
							2 – 10 <span class='text-base'>µm</span>
						</p>
					</div>
				</div>
			</section>

			<section class='grid gap-8'>
				<h2 class='text-2xl md:text-3xl font-bold tracking-tight'>Quality Assurance & Testing</h2>
				<div class='grid gap-6 md:grid-cols-2 lg:grid-cols-4'>
					<div
						class='rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-6 text-center'
					>
						<div
							class='inline-flex items-center justify-center h-12 w-12 rounded-full bg-accent/10 text-accent'
						>
							<CheckIcon class='w-6 h-6' />
						</div>
						<p class='mt-4 font-semibold text-lg'>Thickness Testing</p>
					</div>
					<div
						class='rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 text-center'
					>
						<div
							class='inline-flex items-center justify-center h-12 w-12 rounded-full bg-accent/10 text-accent'
						>
							<CheckIcon class='w-6 h-6' />
						</div>
						<p class='mt-4 font-semibold text-lg'>Regular Bath Maintenance & Solution Control</p>
					</div>
					<div
						class='rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 text-center'
					>
						<div
							class='inline-flex items-center justify-center h-12 w-12 rounded-full bg-accent/10 text-accent'
						>
							<CheckIcon class='w-6 h-6' />
						</div>
						<p class='mt-4 font-semibold text-lg'>Adhesion and Peel Tests (if required)</p>
					</div>
					<div
						class='rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 text-center'
					>
						<div
							class='inline-flex items-center justify-center h-12 w-12 rounded-full bg-accent/10 text-accent'
						>
							<CheckIcon class='w-6 h-6' />
						</div>
						<p class='mt-4 font-semibold text-lg'>
							Certificates of Conformance (RoHS, Material TDS) on request
						</p>
					</div>
				</div>
			</section>

			<section class='grid gap-8'>
				<h2 class='text-2xl md:text-3xl font-bold tracking-tight'>Fast Turnaround & Logistics</h2>
				<div class='grid gap-6 md:grid-cols-2 lg:grid-cols-3'>
					<div
						class='rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 text-center'
					>
						<div
							class='inline-flex items-center justify-center h-12 w-12 rounded-full bg-accent/10 text-accent'
						>
							<CheckIcon class='w-6 h-6' />
						</div>
						<p class='mt-4 font-semibold text-lg'>Standard Lead Time: 1 Day</p>
					</div>
					<div
						class='rounded-xl md:rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-5 md:p-6 text-center'
					>
						<div
							class='inline-flex items-center justify-center h-12 w-12 rounded-full bg-accent/10 text-accent'
						>
							<CheckIcon class='w-6 h-6' />
						</div>
						<p class='mt-4 font-semibold text-lg'>Expedited Service: 24x7 Operations</p>
					</div>
					<div
						class='rounded-2xl border border-stone-200 dark:border-white/10 bg-white/70 dark:bg-white/5 p-6 text-center'
					>
						<div
							class='inline-flex items-center justify-center h-12 w-12 rounded-full bg-accent/10 text-accent'
						>
							<CheckIcon class='w-6 h-6' />
						</div>
						<p class='mt-4 font-semibold text-lg'>Safe Packaging & Logistics</p>
					</div>
				</div>
			</section>

			<section class='grid gap-8'>
				<h2 class='text-2xl md:text-3xl font-bold tracking-tight'>Industries We Serve</h2>
				<div class='flex flex-wrap justify-center md:justify-start gap-3'>
					<span class='px-4 py-2 rounded-full bg-accent/10 text-accent text-sm font-medium'
						>Electrical</span
					>
					<span class='px-4 py-2 rounded-full bg-accent/10 text-accent text-sm font-medium'
						>Automobile</span
					>
					<span class='px-4 py-2 rounded-full bg-accent/10 text-accent text-sm font-medium'
						>Capacitors</span
					>
					<span class='px-4 py-2 rounded-full bg-accent/10 text-accent text-sm font-medium'
						>Switchgear</span
					>
					<span class='px-4 py-2 rounded-full bg-accent/10 text-accent text-sm font-medium'
						>Electronics</span
					>
				</div>
			</section>

			<!-- OEM Dedicated Lines -->
			<section class='grid gap-8'>
				<div
					class='rounded-2xl md:rounded-3xl border border-accent/20 bg-accent/5 p-6 md:p-12 text-center md:text-left'
				>
					<div class='grid md:grid-cols-2 gap-8 items-center'>
						<div>
							<h2 class='text-2xl md:text-3xl font-bold tracking-tight text-accent'>
								Dedicated OEM Plating Plants
							</h2>
							<p class='mt-4 text-stone-700 dark:text-stone-300 leading-relaxed text-lg'>
								For high-volume manufacturers, we don't just offer job-shop services—we build
								completely dedicated surface treatment lines. If your project requires massive
								throughput, specialized chemistry (like Silver, Gold, or Zinc-Nickel), or an
								entirely captive plant, Platinex Industries is ready to invest and engineer the
								perfect solution.
							</p>
							<div class='mt-8'>
								<a
									href='/post/oem-dedicated-surface-treatment-lines'
									class='inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-stone-900 dark:bg-white text-white dark:text-stone-900 font-semibold hover:bg-stone-800 dark:hover:bg-stone-100 transition-colors'
								>
									Read The OEM Partnership Guide
									<svg
										xmlns='http://www.w3.org/2000/svg'
										class='h-5 w-5'
										fill='none'
										viewBox='0 0 24 24'
										stroke='currentColor'
									>
										<path
											stroke-linecap='round'
											stroke-linejoin='round'
											stroke-width='2'
											d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
									</svg>
								</a>
							</div>
						</div>
						<div class='hidden md:flex justify-center'>
							<div
								class='w-full max-w-sm aspect-square bg-white dark:bg-stone-900 rounded-2xl shadow-xl flex items-center justify-center border border-stone-200 dark:border-stone-800 p-8 relative overflow-hidden'
							>
								<div
									class='absolute top-0 right-0 w-32 h-32 bg-accent/10 rounded-bl-full -mr-8 -mt-8'
								>
								</div>
								<div
									class='absolute bottom-0 left-0 w-24 h-24 bg-accent/5 rounded-tr-full -ml-8 -mb-8'
								>
								</div>
								<div class='relative z-10 text-center'>
									<div
										class='inline-flex items-center justify-center w-20 h-20 rounded-full bg-accent text-white mb-6 shadow-lg shadow-accent/30'
									>
										<svg
											xmlns='http://www.w3.org/2000/svg'
											class='w-10 h-10'
											fill='none'
											viewBox='0 0 24 24'
											stroke='currentColor'
										>
											<path
												stroke-linecap='round'
												stroke-linejoin='round'
												stroke-width='2'
												d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
											></path>
										</svg>
									</div>
									<h3 class='text-2xl font-bold text-stone-900 dark:text-white'>Captive Lines</h3>
									<p class='text-stone-500 dark:text-stone-400 mt-2 font-medium'>
										Engineered for Scale
									</p>
								</div>
							</div>
						</div>
