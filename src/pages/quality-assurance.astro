---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Image } from 'astro:assets'
import CheckIcon from '../components/icons/CheckIcon.astro'
import xrfImage from '../assets/images/trivalent_zinc_plating.png'
import saltSprayImage from '../assets/images/zinc_plating_hardware.png'
import titrationImage from '../assets/images/PCB_copper_layer_electroplating_machine.jpg'

const schema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: 'Quality Assurance & Laboratory Testing | Platinex Industries',
	description:
		'Our in-house analytical laboratory ensures precision electroplating through XRF thickness testing, salt spray corrosion testing, and strict chemical titration.',
	publisher: {
		'@type': 'Organization',
		name: 'Platinex Industries'
	}
}
---

<BaseLayout
	title='Quality Assurance & Lab Testing | Platinex Industries'
	description='Dedicated in-house laboratory for XRF thickness testing, Salt Spray testing, and chemical analysis. ISO 9001 and RoHS compliant electroplating in Nashik.'
>
	<script type='application/ld+json' set:html={JSON.stringify(schema)} />

	<div class='mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 py-12'>
		<!-- Header -->
		<div class='max-w-3xl mb-16'>
			<h1 class='text-4xl md:text-6xl font-extrabold tracking-tight mb-6'>
				Quality <span class='text-accent'>Assurance</span> & Laboratory
			</h1>
			<p class='text-xl text-stone-600 dark:text-stone-400 leading-relaxed'>
				At Platinex Industries, quality isn't just a final check—it's engineered into every step of
				the process. Our dedicated in-house laboratory ensures every component meets your exact
				micrometer-level specifications.
			</p>
		</div>

		<!-- Certification Grid -->
		<div class='grid md:grid-cols-3 gap-8 mb-20'>
			<div
				class='p-8 rounded-3xl bg-stone-50 dark:bg-stone-900 border border-stone-200 dark:border-white/10'
			>
				<div class='text-accent mb-4'>
					<svg class='w-12 h-12' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
						<path
							stroke-linecap='round'
							stroke-linejoin='round'
							stroke-width='1.5'
							d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
						></path>
					</svg>
				</div>
				<h3 class='text-xl font-bold mb-2'>ISO 9001:2015</h3>
				<p class='text-stone-600 dark:text-stone-400 text-sm'>
					Strict adherence to international quality management systems for consistent manufacturing
					and operational excellence.
				</p>
			</div>
			<div
				class='p-8 rounded-3xl bg-stone-50 dark:bg-stone-900 border border-stone-200 dark:border-white/10'
			>
				<div class='text-accent mb-4'>
					<svg class='w-12 h-12' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
						<path
							stroke-linecap='round'
							stroke-linejoin='round'
							stroke-width='1.5'
							d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
						></path>
					</svg>
				</div>
				<h3 class='text-xl font-bold mb-2'>RoHS & REACH</h3>
				<p class='text-stone-600 dark:text-stone-400 text-sm'>
					Committed to environmental safety with 100% hexavalent chromium-free and lead-free
					finishing options.
				</p>
			</div>
			<div
				class='p-8 rounded-3xl bg-stone-50 dark:bg-stone-900 border border-stone-200 dark:border-white/10'
			>
				<div class='text-accent mb-4'>
					<svg class='w-12 h-12' fill='none' viewBox='0 0 24 24' stroke='currentColor'>
						<path
							stroke-linecap='round'
							stroke-linejoin='round'
							stroke-width='1.5'
							d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'
						></path>
					</svg>
				</div>
				<h3 class='text-xl font-bold mb-2'>Zero-Defect Goal</h3>
				<p class='text-stone-600 dark:text-stone-400 text-sm'>
					Utilizing statistical process control (SPC) to monitor bath chemistry and ensure
					lot-to-lot consistency.
				</p>
			</div>
		</div>

		<!-- Technical Testing Sections -->
		<div class='space-y-24 pb-20'>
			<!-- XRF Thickness Testing -->
			<div class='grid md:grid-cols-2 gap-12 items-center'>
				<div>
					<h2 class='text-3xl font-bold mb-6'>XRF Thickness Measurement</h2>
					<p class='text-stone-600 dark:text-stone-400 mb-8'>
						We utilize advanced X-Ray Fluorescence (XRF) technology to non-destructively measure
						coating thickness. This ensures that every component—whether plated with Tin, Nickel, or
						Copper—meets the precise micrometer (μm) specifications required by your engineering
						team.
					</p>
					<ul class='space-y-3'>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Multi-layer thickness analysis
						</li>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Non-destructive testing method
						</li>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Verification of alloy composition
						</li>
					</ul>
				</div>
				<div
					class='aspect-video rounded-3xl overflow-hidden bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10'
				>
					<Image
						src={xrfImage}
						alt='XRF Thickness Testing'
						class='w-full h-full object-cover'
						width={800}
						height={450}
					/>
				</div>
			</div>

			<!-- Salt Spray Testing -->
			<div class='grid md:grid-cols-2 gap-12 items-center'>
				<div
					class='order-2 md:order-1 aspect-video rounded-3xl overflow-hidden bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10'
				>
					<Image
						src={saltSprayImage}
						alt='Salt Spray Testing Results'
						class='w-full h-full object-cover'
						width={800}
						height={450}
					/>
				</div>
				<div class='order-1 md:order-2'>
					<h2 class='text-3xl font-bold mb-6'>Salt Spray Corrosion Testing</h2>
					<p class='text-stone-600 dark:text-stone-400 mb-8'>
						To guarantee long-term performance in harsh environments, we subject samples to
						accelerated corrosion testing in accordance with **ASTM B117** standards. Our
						high-performance Zinc and Zinc-Nickel finishes are verified for 500+ to 1,000+ hours of
						salt spray resistance.
					</p>
					<ul class='space-y-3'>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> ASTM B117 Standard compliance
						</li>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Accelerated life-cycle validation
						</li>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Red rust & White rust prevention analysis
						</li>
					</ul>
				</div>
			</div>

			<!-- Chemical Titration -->
			<div class='grid md:grid-cols-2 gap-12 items-center'>
				<div>
					<h2 class='text-3xl font-bold mb-6'>Wet Chemical Analysis</h2>
					<p class='text-stone-600 dark:text-stone-400 mb-8'>
						The secret to a perfect finish is perfect chemistry. Our lab performs daily chemical
						titration and Hull Cell analysis to maintain optimal metal concentration, pH levels, and
						additive balance in all plating baths.
					</p>
					<ul class='space-y-3'>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Daily bath analysis and maintenance
						</li>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Hull Cell testing for plating quality
						</li>
						<li class='flex items-center gap-3 text-stone-700 dark:text-stone-300'>
							<CheckIcon class='w-5 h-5 text-accent' /> Effluent treatment monitoring
						</li>
					</ul>
				</div>
				<div
					class='aspect-video rounded-3xl overflow-hidden bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10'
				>
					<Image
						src={titrationImage}
						alt='Laboratory Analysis and Titration'
						class='w-full h-full object-cover'
						width={800}
						height={450}
					/>
				</div>
			</div>
		</div>

		<!-- Quality CTA -->
		<div class='bg-accent rounded-3xl p-8 md:p-16 text-center text-white'>
			<h2 class='text-3xl md:text-5xl font-bold mb-6'>Need a Certifiable Finish?</h2>
			<p class='text-xl text-white/80 mb-10 max-w-2xl mx-auto'>
				We provide detailed Inspection Reports (IR) and Certificates of Conformance (CoC) for every
				batch upon request.
			</p>
			<a
				href='/#contact'
				class='inline-flex px-8 py-4 bg-white text-accent font-bold rounded-xl hover:bg-stone-50 transition-colors shadow-xl'
			>
				Contact Engineering Lab
			</a>
		</div>
	</div>
</BaseLayout>
