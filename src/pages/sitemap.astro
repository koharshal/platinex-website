---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('blog')
// Sort posts by date
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const services = [
	{ title: 'Copper Plating', url: '/services/copper-plating' },
	{ title: 'Nickel Plating', url: '/services/nickel-plating' },
	{ title: 'Zinc Plating', url: '/services/zinc-plating' },
	{ title: 'Tin Plating', url: '/services/tin-plating' }
]
---

<BaseLayout
	title='Sitemap - Platinex Industries'
	description='Sitemap and document tree for Platinex Industries.'
>
	<div class='mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8 py-12 md:py-20'>
		<h1
			class='text-4xl md:text-5xl font-extrabold tracking-tight mb-8 text-stone-900 dark:text-white'
		>
			Site <span class='accent-underline'>Map</span>
		</h1>
		<p class='text-lg text-stone-600 dark:text-stone-400 mb-12'>
			A complete overview of the Platinex Industries website structure.
		</p>

		<div
			class='bg-white/70 dark:bg-white/5 rounded-3xl border border-stone-200 dark:border-white/10 p-8 md:p-12'
		>
			<ul class='space-y-8'>
				{/* Core Pages */}
				<li>
					<h2
						class='text-2xl font-bold text-stone-900 dark:text-white mb-4 flex items-center gap-2'
					>
						<div class='w-2 h-2 rounded-full bg-accent'></div> Core Pages
					</h2>
					<ul class='ml-6 space-y-3 border-l-2 border-stone-200 dark:border-stone-800 pl-4'>
						<li>
							<a
								href='/'
								class='text-lg font-medium text-stone-700 dark:text-stone-300 hover:text-accent transition-colors'
								>Home</a
							>
						</li>
						<li>
							<a
								href='/#contact'
								class='text-lg font-medium text-stone-700 dark:text-stone-300 hover:text-accent transition-colors'
								>Contact Us</a
							>
						</li>
					</ul>
				</li>

				{/* Services */}
				<li>
					<h2
						class='text-2xl font-bold text-stone-900 dark:text-white mb-4 flex items-center gap-2'
					>
						<div class='w-2 h-2 rounded-full bg-accent'></div> Services
					</h2>
					<ul class='ml-6 space-y-3 border-l-2 border-stone-200 dark:border-stone-800 pl-4'>
						<li>
							<a
								href='/services'
								class='text-lg font-medium text-stone-700 dark:text-stone-300 hover:text-accent transition-colors'
								>Services Hub</a
							>
						</li>
						{
							services.map((service) => (
								<li>
									<a
										href={service.url}
										class='text-base text-stone-600 dark:text-stone-400 hover:text-accent transition-colors block py-1'
									>
										↳ {service.title}
									</a>
								</li>
							))
						}
					</ul>
				</li>

				{/* Blog & Resources */}
				<li>
					<h2
						class='text-2xl font-bold text-stone-900 dark:text-white mb-4 flex items-center gap-2'
					>
						<div class='w-2 h-2 rounded-full bg-accent'></div> Blog & Resources
					</h2>
					<ul class='ml-6 space-y-3 border-l-2 border-stone-200 dark:border-stone-800 pl-4'>
						<li>
							<a
								href='/blog'
								class='text-lg font-medium text-stone-700 dark:text-stone-300 hover:text-accent transition-colors'
								>Blog Hub (All Articles)</a
							>
						</li>
						{
							posts.map((post) => (
								<li>
									<a
										href={`/post/${post.slug}`}
										class='text-base text-stone-600 dark:text-stone-400 hover:text-accent transition-colors block py-1'
									>
										↳ {post.data.title}
									</a>
								</li>
							))
						}
					</ul>
				</li>
			</ul>
		</div>
	</div>
</BaseLayout>
