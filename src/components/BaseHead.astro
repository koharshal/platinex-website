---
import { siteConfig } from '../data/site.config'
import '../styles/global.css'
import { ViewTransitions } from 'astro:transitions'

export interface Props {
	title: string
	description?: string
	ogImage?: string | undefined
	articleDate?: string | undefined
}

const { title, description = siteConfig.description, ogImage, articleDate } = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const socialImageURL = new URL(ogImage ? ogImage : '/open-graph.png', Astro.url).href

const titleSeparator = '•'

const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`

const isHomePage = Astro.url.pathname === '/'

const localBusinessSchema = {
	'@context': 'https://schema.org',
	'@type': ['LocalBusiness', 'ManufacturingBusiness'],
	name: 'Platinex Industries Private Limited',
	description:
		'Electroplating services including copper, nickel, zinc, and tin plating for electrical, switchgear, automobile, and electronics industries in Nashik, Maharashtra, India.',
	url: 'https://platinex.in/',
	telephone: '+918600146841',
	email: 'platinexindustries@gmail.com',
	image: 'https://platinex.in/open-graph.png',
	logo: 'https://platinex.in/favicon.png',
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Plot no. 156/3, Ambad-Vilholi MIDC Link Road, Vilholi',
		addressLocality: 'Nashik',
		addressRegion: 'Maharashtra',
		postalCode: '422010',
		addressCountry: 'IN'
	},
	geo: {
		'@type': 'GeoCoordinates',
		latitude: '20.0059',
		longitude: '73.7903'
	},
	openingHoursSpecification: {
		'@type': 'OpeningHoursSpecification',
		dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
		opens: '00:00',
		closes: '23:59'
	},
	priceRange: '₹₹',
	areaServed: [
		{ '@type': 'City', name: 'Nashik' },
		{ '@type': 'State', name: 'Maharashtra' },
		{ '@type': 'Country', name: 'India' }
	],
	hasOfferCatalog: {
		'@type': 'OfferCatalog',
		name: 'Electroplating Services',
		itemListElement: [
			{
				'@type': 'Offer',
				itemOffered: {
					'@type': 'Service',
					name: 'Copper Plating',
					description:
						'High-conductivity copper plating for bus bars, electrical components, and grounding parts. 3–30 µm, barrel process.'
				}
			},
			{
				'@type': 'Offer',
				itemOffered: {
					'@type': 'Service',
					name: 'Nickel Plating',
					description:
						'Hard, arc-resistant nickel plating for fasteners, shafts, valves and connectors. 2–25 µm, bright/dull electrolytic.'
				}
			},
			{
				'@type': 'Offer',
				itemOffered: {
					'@type': 'Service',
					name: 'Zinc Plating',
					description:
						'Sacrificial rust protection zinc plating with trivalent passivation for hardware, fasteners, and automotive parts. 2–12 µm.'
				}
			},
			{
				'@type': 'Offer',
				itemOffered: {
					'@type': 'Service',
					name: 'Tin Plating',
					description:
						'Solderable tin plating for switchgear terminals and electrical contacts. 2–10 µm, bright/matte.'
				}
			}
		]
	}
}
---

<!-- Google tag (gtag.js) -->
<script async src='https://www.googletagmanager.com/gtag/js?id=G-215RZNFPMY'></script>
<script is:inline>
	window.dataLayer = window.dataLayer || []
	function gtag() {
		dataLayer.push(arguments)
	}
	gtag('js', new Date())

	gtag('config', 'G-215RZNFPMY')
</script>

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width,initial-scale=1' />
<link rel='icon' type='image/png' href='/favicon.png' />
<link rel='shortcut icon' type='image/png' href='/favicon.png' />
<meta name='generator' content={Astro.generator} />

<!-- Fonts: Inter (body) and Montserrat (headings) - Self-hosted -->
<link rel='preload' href='/fonts/inter-400.woff2' as='font' type='font/woff2' crossorigin />
<link rel='preload' href='/fonts/inter-500.woff2' as='font' type='font/woff2' crossorigin />
<link rel='preload' href='/fonts/inter-700.woff2' as='font' type='font/woff2' crossorigin />
<link rel='preload' href='/fonts/montserrat-600.woff2' as='font' type='font/woff2' crossorigin />
<link rel='preload' href='/fonts/montserrat-700.woff2' as='font' type='font/woff2' crossorigin />
<link rel='preload' href='/fonts/montserrat-800.woff2' as='font' type='font/woff2' crossorigin />

<!-- Canonical URL -->
<link rel='canonical' href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{siteTitle}</title>

<!-- ViewTransitions  -->
<ViewTransitions />

<!-- SEO -->
<meta name='title' content={siteTitle} />
<meta name='description' content={description} />
<meta name='author' content={siteConfig.author} />
<meta
	name='keywords'
	content='electroplating Nashik, plating supplier Nashik, copper plating India, nickel plating Nashik, zinc plating Maharashtra, tin plating switchgear, electroplating MIDC Nashik, metal finishing India, barrel plating Nashik, electroplating company India'
/>

<!-- Geo / Local SEO Meta -->
<meta name='geo.region' content='IN-MH' />
<meta name='geo.placename' content='Nashik' />
<meta name='geo.position' content='20.0059;73.7903' />
<meta name='ICBM' content='20.0059, 73.7903' />

<!-- Open Graph / Facebook -->
<meta property='og:type' content={articleDate ? 'article' : 'website'} />
<meta property='og:url' content={Astro.url} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={socialImageURL} />
<meta property='og:locale' content='en_IN' />
<meta property='og:site_name' content='Platinex Industries' />
{
	articleDate && (
		<>
			<meta property='article:author' content={siteConfig.author} />
			<meta property='article:published_time' content={articleDate} />
		</>
	)
}

<!-- Twitter -->
<meta property='twitter:card' content='summary_large_image' />
<meta property='twitter:url' content={Astro.url} />
<meta property='twitter:title' content={title} />
<meta property='twitter:description' content={description} />
<meta property='twitter:image' content={socialImageURL} />

<!-- RSS auto-discovery -->
<link rel='alternate' type='application/rss+xml' title={siteConfig.title} href='/rss.xml' />

<!-- LocalBusiness Structured Data (JSON-LD) -->
{isHomePage && <script type='application/ld+json' set:html={JSON.stringify(localBusinessSchema)} />}
