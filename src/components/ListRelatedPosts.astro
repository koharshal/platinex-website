---
import type { CollectionEntry } from 'astro:content'

import { cn } from '@/utils'
import { Image } from 'astro:assets'

type Props = {
	posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props
---

<section class={cn(`grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mt-4`)}>
	{
		posts.length > 0 ? (
			posts.map((post) => {
				return (
					<a
						href={`/post/${post.slug}/`}
						class='group flex flex-col gap-3 rounded-2xl border border-stone-200 dark:border-white/10 bg-white/50 dark:bg-stone-900/50 hover:bg-stone-50 dark:hover:bg-stone-800/50 p-3 md:p-4 transition-all duration-200 hover:shadow-md'
					>
						<div class='aspect-video overflow-hidden rounded-xl bg-stone-100 dark:bg-stone-800'>
							<Image
								src={post.data.heroImage}
								width={400}
								height={225}
								format='webp'
								class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
								alt={`img of ${post.data.title}`}
							/>
						</div>
						<h3 class='font-semibold text-stone-900 dark:text-white line-clamp-2 leading-snug'>
							{post.data.title}
						</h3>
					</a>
				)
			})
		) : (
			<span class='text-gray-500'>There are no related posts yet. 😢</span>
		)
	}
</section>
